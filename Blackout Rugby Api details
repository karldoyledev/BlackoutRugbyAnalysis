  &lt;leagueid&gt;6&lt;/leagueid&gt;
  &lt;played&gt;14&lt;/played&gt;
  &lt;w&gt;13&lt;/w&gt;
  &lt;l&gt;1&lt;/l&gt;
  &lt;d&gt;0&lt;/d&gt;
  &lt;for&gt;388&lt;/for&gt;
  &lt;against&gt;160&lt;/against&gt;
  &lt;b1&gt;7&lt;/b1&gt;
