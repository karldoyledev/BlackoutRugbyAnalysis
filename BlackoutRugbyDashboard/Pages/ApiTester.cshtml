@page
@model ApiTesterModel
@{
    ViewData["Title"] = "API Tester";
}

<style>
    .api-tester-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
        gap: 20px;
        margin: 20px 0;
    }

    .endpoint-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 20px;
        background: #fafafa;
        transition: box-shadow 0.2s;
    }

    .endpoint-card:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .endpoint-card h3 {
        margin-top: 0;
        margin-bottom: 5px;
        color: #2e5c65;
        font-size: 1.1em;
    }

    .endpoint-code {
        font-size: 0.85em;
        color: #666;
        margin-bottom: 15px;
        font-family: monospace;
        background: #f0f0f0;
        padding: 3px 6px;
        border-radius: 3px;
        display: inline-block;
    }

    .form-group {
        margin-bottom: 12px;
    }

    .form-group label {
        display: block;
        margin-bottom: 4px;
        font-weight: 600;
        color: #555;
        font-size: 0.9em;
    }

    .form-group input,
    .form-group select {
        width: 100%;
        padding: 6px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 0.9em;
        font-family: monospace;
        box-sizing: border-box;
    }

    .form-group input:focus,
    .form-group select:focus {
        outline: none;
        border-color: #2e5c65;
        box-shadow: 0 0 4px rgba(46, 92, 101, 0.2);
    }

    .button-group {
        display: flex;
        gap: 8px;
        margin-top: 15px;
    }

    button {
        flex: 1;
        padding: 8px 12px;
        border: none;
        border-radius: 4px;
        font-size: 0.9em;
        cursor: pointer;
        font-weight: 600;
        transition: background-color 0.2s;
    }

    .btn-primary {
        background-color: #2e5c65;
        color: white;
    }

    .btn-primary:hover {
        background-color: #1e3d45;
    }

    .btn-secondary {
        background-color: #ddd;
        color: #333;
    }

    .btn-secondary:hover {
        background-color: #bbb;
    }

    .response-container {
        margin-top: 15px;
        max-height: 400px;
        overflow-y: auto;
    }

    .response-box {
        background: white;
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 12px;
        font-family: 'Courier New', monospace;
        font-size: 0.8em;
        white-space: pre-wrap;
        word-wrap: break-word;
        color: #333;
        line-height: 1.3;
    }

    .response-box.error {
        background: #fee;
        color: #c33;
        border-color: #fcc;
    }

    .response-box.success {
        background: #f0f8f0;
        color: #333;
        border-color: #9d9;
    }

    .response-box.loading {
        color: #666;
        font-style: italic;
    }

    .parameter-required {
        color: #c33;
    }

    .parameter-note {
        font-size: 0.8em;
        color: #666;
        margin-top: 2px;
        font-style: italic;
    }

    .section-title {
        font-size: 1.3em;
        font-weight: 700;
        color: #333;
        margin: 30px 0 20px 0;
        padding-bottom: 10px;
        border-bottom: 2px solid #2e5c65;
    }

    .no-response {
        color: #999;
        font-style: italic;
    }

    @@media (max-width: 600px) {
        .api-tester-container {
            grid-template-columns: 1fr;
        }
    }
</style>

<h2 style="color: #333; margin: 20px 0;">Blackout Rugby API Tester</h2>
<p style="color: #666; margin-bottom: 30px;">Test all available Blackout Rugby API endpoints. Default values are pre-filled for convenience.</p>

<div id="endpointsContainer"></div>

<script>
    const endpoints = {
        countries: {
            code: 'c',
            category: 'Data Retrieval',
            parameters: [
                { name: 'iso', type: 'text', label: 'Country ISO', placeholder: 'e.g., NZ', required: false, default: '' }
            ]
        },
        divisions: {
            code: 'd',
            category: 'Data Retrieval',
            parameters: [
                { name: 'divisionid', type: 'number', label: 'Division ID', placeholder: 'e.g., 123', required: false, default: '' }
            ]
        },
        finances: {
            code: 'fi',
            category: 'Data Retrieval',
            parameters: [
                { name: 'season', type: 'number', label: 'Season', placeholder: 'e.g., 2024', required: true, default: new Date().getFullYear() },
                { name: 'round', type: 'number', label: 'Round', placeholder: 'e.g., 1', required: true, default: 1 }
            ]
        },
        fixtures: {
            code: 'f',
            category: 'Data Retrieval',
            parameters: [
                { name: 'teamid', type: 'number', label: 'Team ID', placeholder: 'e.g., 45047', required: false, default: 45047 },
                { name: 'fixtureid', type: 'number', label: 'Fixture ID', placeholder: 'e.g., 123', required: false, default: '' }
            ]
        },
        fixturestats: {
            code: 'fs',
            category: 'Data Retrieval',
            parameters: [
                { name: 'fixtureid', type: 'number', label: 'Fixture ID', placeholder: 'e.g., 123', required: true, default: '' }
            ]
        },
        leagues: {
            code: 'l',
            category: 'Data Retrieval',
            parameters: [
                { name: 'leagueid', type: 'number', label: 'League ID', placeholder: 'e.g., 123', required: false, default: '' }
            ]
        },
        lineups: {
            code: 'lu',
            category: 'Data Retrieval',
            parameters: [
                { name: 'teamid', type: 'number', label: 'Team ID', placeholder: 'e.g., 45047', required: true, default: 45047 },
                { name: 'fixtureid', type: 'number', label: 'Fixture ID', placeholder: 'e.g., 123', required: false, default: '' }
            ]
        },
        mail: {
            code: 'ma',
            category: 'Data Retrieval',
            parameters: [
                { name: 'folderid', type: 'text', label: 'Folder ID', placeholder: 'e.g., 1', required: false, default: '' }
            ]
        },
        matchcommentary: {
            code: 'me',
            category: 'Live Data',
            parameters: [
                { name: 'fixtureid', type: 'number', label: 'Fixture ID', placeholder: 'e.g., 123', required: true, default: '' }
            ]
        },
        matchscore: {
            code: 'ls',
            category: 'Live Data',
            parameters: [
                { name: 'fixtureid', type: 'number', label: 'Fixture ID', placeholder: 'e.g., 123', required: true, default: '' }
            ]
        },
        matchsummary: {
            code: 'ms',
            category: 'Live Data',
            parameters: [
                { name: 'fixtureid', type: 'number', label: 'Fixture ID', placeholder: 'e.g., 123', required: false, default: '' }
            ]
        },
        members: {
            code: 'm',
            category: 'Data Retrieval',
            parameters: [
                { name: 'memberid', type: 'number', label: 'Member ID', placeholder: 'e.g., 202665', required: false, default: 202665 }
            ]
        },
        playerhistory: {
            code: 'ph',
            category: 'Data Retrieval',
            parameters: [
                { name: 'playerid', type: 'number', label: 'Player ID', placeholder: 'e.g., 123', required: true, default: '' }
            ]
        },
        players: {
            code: 'p',
            category: 'Data Retrieval',
            parameters: [
                { name: 'playerid', type: 'number', label: 'Player ID', placeholder: 'e.g., 123', required: false, default: '' },
                { name: 'teamid', type: 'number', label: 'Team ID', placeholder: 'e.g., 45047', required: false, default: 45047 }
            ]
        },
        playerstats: {
            code: 'ps',
            category: 'Data Retrieval',
            parameters: [
                { name: 'playerid', type: 'number', label: 'Player ID', placeholder: 'e.g., 123', required: true, default: '' }
            ]
        },
        rankings: {
            code: 'rk',
            category: 'Data Retrieval',
            parameters: [
                { name: 'leagueid', type: 'number', label: 'League ID', placeholder: 'e.g., 123', required: false, default: '' }
            ]
        },
        teams: {
            code: 't',
            category: 'Data Retrieval',
            parameters: [
                { name: 'teamid', type: 'number', label: 'Team ID', placeholder: 'e.g., 45047', required: false, default: 45047 }
            ]
        }
    };

    function initializeEndpoints() {
        const container = document.getElementById('endpointsContainer');
        container.innerHTML = '';

        // Group endpoints by category
        const categories = {};
        for (const [key, config] of Object.entries(endpoints)) {
            const cat = config.category;
            if (!categories[cat]) categories[cat] = [];
            categories[cat].push({ key, ...config });
        }

        // Render by category
        for (const [category, items] of Object.entries(categories)) {
            const title = document.createElement('h3');
            title.className = 'section-title';
            title.textContent = category;
            container.appendChild(title);

            const grid = document.createElement('div');
            grid.className = 'api-tester-container';
            
            items.forEach(endpoint => {
                const card = createEndpointCard(endpoint.key, endpoint);
                grid.appendChild(card);
            });

            container.appendChild(grid);
        }
    }

    function createEndpointCard(key, config) {
        const card = document.createElement('div');
        card.className = 'endpoint-card';
        card.id = `card-${key}`;

        let html = `
            <h3>${key.charAt(0).toUpperCase() + key.slice(1)}</h3>
            <span class="endpoint-code">r=${config.code}</span>
            <form id="form-${key}" onsubmit="return false;">
        `;

        config.parameters.forEach(param => {
            const requiredMark = param.required ? '<span class="parameter-required">*</span>' : '';
            const defaultVal = param.default || '';
            html += `
                <div class="form-group">
                    <label for="${key}-${param.name}">
                        ${param.label} ${requiredMark}
                    </label>
                    <input 
                        type="${param.type}" 
                        id="${key}-${param.name}" 
                        name="${param.name}"
                        placeholder="${param.placeholder}"
                        value="${defaultVal}"
                    />
                </div>
            `;
        });

        html += `
            <div class="button-group">
                <button type="button" class="btn-primary" onclick="sendRequest('${key}')">Test</button>
                <button type="button" class="btn-secondary" onclick="resetForm('${key}')">Reset</button>
            </div>
            <div class="response-container">
                <div id="response-${key}" class="response-box no-response">No response yet</div>
            </div>
            </form>
        `;

        card.innerHTML = html;
        return card;
    }

    async function sendRequest(endpoint) {
        const form = document.getElementById(`form-${endpoint}`);
        const responseBox = document.getElementById(`response-${endpoint}`);
        const params = new URLSearchParams();

        // Collect form data
        const formElements = form.querySelectorAll('input');
        formElements.forEach(input => {
            if (input.value) {
                params.append(input.name, input.value);
            }
        });

        responseBox.className = 'response-box loading';
        responseBox.textContent = '⏳ Loading...';

        try {
            const response = await fetch(`/api/test?endpoint=${endpoint}&${params.toString()}`);
            const data = await response.json();

            if (data.success) {
                responseBox.className = 'response-box success';
                responseBox.textContent = data.response;
            } else {
                responseBox.className = 'response-box error';
                responseBox.textContent = `Error: ${data.error}`;
            }
        } catch (error) {
            responseBox.className = 'response-box error';
            responseBox.textContent = `Error: ${error.message}`;
        }
    }

    function resetForm(endpoint) {
        const config = endpoints[endpoint];
        config.parameters.forEach(param => {
            const input = document.getElementById(`${endpoint}-${param.name}`);
            if (input) {
                input.value = param.default || '';
            }
        });
        
        const responseBox = document.getElementById(`response-${endpoint}`);
        responseBox.className = 'response-box no-response';
        responseBox.textContent = 'No response yet';
    }

    // Initialize on load
    document.addEventListener('DOMContentLoaded', initializeEndpoints);
</script>
