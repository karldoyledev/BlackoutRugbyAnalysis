@page
@model ApiTesterModel
@{
    ViewData["Title"] = "API Tester";
}

<style>
    .api-tester-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
        gap: 20px;
        margin: 20px 0;
    }

    .endpoint-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 20px;
        background: #fafafa;
        transition: box-shadow 0.2s;
    }

    .endpoint-card:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .endpoint-card h3 {
        margin-top: 0;
        margin-bottom: 5px;
        color: #2e5c65;
        font-size: 1.1em;
    }

    .endpoint-code {
        font-size: 0.85em;
        color: #666;
        margin-bottom: 15px;
        font-family: monospace;
        background: #f0f0f0;
        padding: 3px 6px;
        border-radius: 3px;
        display: inline-block;
    }

    .form-group {
        margin-bottom: 12px;
    }

    .form-group label {
        display: block;
        margin-bottom: 4px;
        font-weight: 600;
        color: #555;
        font-size: 0.9em;
    }

    .form-group input,
    .form-group select {
        width: 100%;
        padding: 6px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 0.9em;
        font-family: monospace;
        box-sizing: border-box;
    }

    .form-group input:focus,
    .form-group select:focus {
        outline: none;
        border-color: #2e5c65;
        box-shadow: 0 0 4px rgba(46, 92, 101, 0.2);
    }

    .checkbox-group label {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
    }

    .checkbox-group input[type="checkbox"] {
        width: auto;
        margin-right: 8px;
        cursor: pointer;
    }

    .button-group {
        display: flex;
        gap: 8px;
        margin-top: 15px;
    }

    button {
        flex: 1;
        padding: 8px 12px;
        border: none;
        border-radius: 4px;
        font-size: 0.9em;
        cursor: pointer;
        font-weight: 600;
        transition: background-color 0.2s;
    }

    .btn-primary {
        background-color: #2e5c65;
        color: white;
    }

    .btn-primary:hover {
        background-color: #1e3d45;
    }

    .btn-secondary {
        background-color: #ddd;
        color: #333;
    }

    .btn-secondary:hover {
        background-color: #bbb;
    }

    .response-container {
        margin-top: 15px;
        max-height: 400px;
        overflow-y: auto;
    }

    .response-box {
        background: white;
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 12px;
        font-family: 'Courier New', monospace;
        font-size: 0.8em;
        white-space: pre-wrap;
        word-wrap: break-word;
        color: #333;
        line-height: 1.3;
    }

    .response-box.error {
        background: #fee;
        color: #c33;
        border-color: #fcc;
    }

    .response-box.success {
        background: #f0f8f0;
        color: #333;
        border-color: #9d9;
    }

    .response-box.loading {
        color: #666;
        font-style: italic;
    }

    .parameter-required {
        color: #c33;
    }

    .parameter-note {
        font-size: 0.8em;
        color: #666;
        margin-top: 2px;
        font-style: italic;
    }

    .section-title {
        font-size: 1.3em;
        font-weight: 700;
        color: #333;
        margin: 30px 0 20px 0;
        padding-bottom: 10px;
        border-bottom: 2px solid #2e5c65;
    }

    .no-response {
        color: #999;
        font-style: italic;
    }

    @@media (max-width: 600px) {
        .api-tester-container {
            grid-template-columns: 1fr;
        }
    }
</style>

