@page
@model ApiTesterModel
@{
    ViewData["Title"] = "API Tester";
}

<style>
    .api-tester-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin: 20px 0;
    }

    .panel {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 20px;
        background: #f9f9f9;
    }

    .panel h2 {
        margin-top: 0;
        margin-bottom: 15px;
        color: #333;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-group label {
        display: block;
        margin-bottom: 5px;
        font-weight: 600;
        color: #555;
        font-size: 0.9em;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        width: 100%;
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 0.9em;
        font-family: monospace;
    }

    .form-group textarea {
        min-height: 300px;
        resize: vertical;
        font-family: 'Courier New', monospace;
    }

    .button-group {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    button {
        flex: 1;
        padding: 10px;
        border: none;
        border-radius: 4px;
        font-size: 0.95em;
        cursor: pointer;
        font-weight: 600;
        transition: background-color 0.2s;
    }

    .btn-primary {
        background-color: #2e5c65;
        color: white;
    }

    .btn-primary:hover {
        background-color: #1e3d45;
    }

    .btn-secondary {
        background-color: #ddd;
        color: #333;
    }

    .btn-secondary:hover {
        background-color: #bbb;
    }

    .response-box {
        background: white;
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 15px;
        min-height: 300px;
        font-family: 'Courier New', monospace;
        font-size: 0.85em;
        white-space: pre-wrap;
        word-wrap: break-word;
        overflow-x: auto;
        color: #333;
        line-height: 1.4;
    }

    .response-box.error {
        background: #fee;
        color: #c33;
        border-color: #fcc;
    }

    .response-box.loading {
        color: #666;
        font-style: italic;
    }

    .endpoint-selector {
        margin-bottom: 20px;
    }

    .help-text {
        font-size: 0.85em;
        color: #666;
        margin-top: 5px;
        font-family: Arial, sans-serif;
    }

    .endpoint-description {
        background: #e8f4f8;
        border-left: 3px solid #2e5c65;
        padding: 10px;
        margin-bottom: 15px;
        border-radius: 2px;
    }

    .endpoint-description h3 {
        margin: 0 0 5px 0;
        color: #2e5c65;
    }

    .endpoint-description p {
        margin: 0;
        font-size: 0.9em;
        color: #555;
    }

    .loading-spinner {
        display: inline-block;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .parameter-required {
        color: #c33;
    }

    @@media (max-width: 1200px) {
        .api-tester-container {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="api-tester-container">
    <div class="panel">
        <h2>API Request Builder</h2>
        
        <div class="endpoint-selector">
            <div class="form-group">
                <label for="endpoint">API Endpoint</label>
                <select id="endpoint" onchange="updateEndpoint()">
                    <option value="">-- Select an endpoint --</option>
                    <option value="countries">Countries (r=c)</option>
                    <option value="divisions">Divisions (r=d)</option>
                    <option value="finances">Finances (r=fi)</option>
                    <option value="fixtures">Fixtures (r=f)</option>
                    <option value="fixturestats">Fixture Statistics (r=fs)</option>
                    <option value="leagues">Leagues (r=l)</option>
                    <option value="lineups">Lineups (r=lu)</option>
                    <option value="mail">Mail (r=ma)</option>
                    <option value="matchcommentary">Match Commentary (r=me)</option>
                    <option value="matchscore">Match Score (r=ls)</option>
                    <option value="matchsummary">Match Summary (r=ms)</option>
                    <option value="members">Members (r=m)</option>
                    <option value="playerhistory">Player History (r=ph)</option>
                    <option value="players">Players (r=p)</option>
                    <option value="playerstats">Player Statistics (r=ps)</option>
                    <option value="rankings">Rankings (r=rk)</option>
                    <option value="teams">Teams (r=t)</option>
                </select>
            </div>

            <div id="endpointDescription" class="endpoint-description" style="display: none;">
                <h3 id="descTitle"></h3>
                <p id="descText"></p>
            </div>
        </div>

        <form id="requestForm">
            <div id="parametersContainer"></div>
            
            <div class="button-group">
                <button type="button" class="btn-primary" onclick="makeRequest()">Send Request</button>
                <button type="button" class="btn-secondary" onclick="clearForm()">Clear</button>
            </div>
        </form>
    </div>

    <div class="panel">
        <h2>Response</h2>
        <div id="responseBox" class="response-box">Select an endpoint and send a request to see the response.</div>
    </div>
</div>

<script>
    const endpoints = {
        countries: {
            code: 'c',
            description: 'Get country information',
            parameters: [
                { name: 'iso', type: 'text', label: 'Country ISO', placeholder: 'e.g., NZ', required: false }
            ]
        },
        divisions: {
            code: 'd',
            description: 'Get division information',
            parameters: [
                { name: 'divisionid', type: 'number', label: 'Division ID', placeholder: 'e.g., 123', required: false }
            ]
        },
        finances: {
            code: 'fi',
            description: 'Get team finances',
            parameters: [
                { name: 'season', type: 'number', label: 'Season <span class="parameter-required">*</span>', placeholder: 'e.g., 2024', required: true },
                { name: 'round', type: 'number', label: 'Round <span class="parameter-required">*</span>', placeholder: 'e.g., 1', required: true }
            ]
        },
        fixtures: {
            code: 'f',
            description: 'Get fixture information',
            parameters: [
                { name: 'teamid', type: 'number', label: 'Team ID', placeholder: 'e.g., 45047', required: false },
                { name: 'fixtureid', type: 'number', label: 'Fixture ID', placeholder: 'e.g., 123', required: false }
            ]
        },
        fixturestats: {
            code: 'fs',
            description: 'Get fixture statistics',
            parameters: [
                { name: 'fixtureid', type: 'number', label: 'Fixture ID <span class="parameter-required">*</span>', placeholder: 'e.g., 123', required: true }
            ]
        },
        leagues: {
            code: 'l',
            description: 'Get league information',
            parameters: [
                { name: 'leagueid', type: 'number', label: 'League ID', placeholder: 'e.g., 123', required: false }
            ]
        },
        lineups: {
            code: 'lu',
            description: 'Get team lineups',
            parameters: [
                { name: 'teamid', type: 'number', label: 'Team ID <span class="parameter-required">*</span>', placeholder: 'e.g., 45047', required: true },
                { name: 'fixtureid', type: 'number', label: 'Fixture ID', placeholder: 'e.g., 123', required: false }
            ]
        },
        mail: {
            code: 'ma',
            description: 'Get mail messages',
            parameters: [
                { name: 'folderid', type: 'text', label: 'Folder ID', placeholder: 'e.g., 1', required: false }
            ]
        },
        matchcommentary: {
            code: 'me',
            description: 'Get match commentary',
            parameters: [
                { name: 'fixtureid', type: 'number', label: 'Fixture ID <span class="parameter-required">*</span>', placeholder: 'e.g., 123', required: true }
            ]
        },
        matchscore: {
            code: 'ls',
            description: 'Get current match score',
            parameters: [
                { name: 'fixtureid', type: 'number', label: 'Fixture ID <span class="parameter-required">*</span>', placeholder: 'e.g., 123', required: true }
            ]
        },
        matchsummary: {
            code: 'ms',
            description: 'Get match summary',
            parameters: [
                { name: 'fixtureid', type: 'number', label: 'Fixture ID', placeholder: 'e.g., 123', required: false }
            ]
        },
        members: {
            code: 'm',
            description: 'Get member information',
            parameters: [
                { name: 'memberid', type: 'number', label: 'Member ID', placeholder: 'e.g., 202665', required: false }
            ]
        },
        playerhistory: {
            code: 'ph',
            description: 'Get player history',
            parameters: [
                { name: 'playerid', type: 'number', label: 'Player ID <span class="parameter-required">*</span>', placeholder: 'e.g., 123', required: true }
            ]
        },
        players: {
            code: 'p',
            description: 'Get player information',
            parameters: [
                { name: 'playerid', type: 'number', label: 'Player ID', placeholder: 'e.g., 123', required: false },
                { name: 'teamid', type: 'number', label: 'Team ID', placeholder: 'e.g., 45047', required: false }
            ]
        },
        playerstats: {
            code: 'ps',
            description: 'Get player statistics',
            parameters: [
                { name: 'playerid', type: 'number', label: 'Player ID <span class="parameter-required">*</span>', placeholder: 'e.g., 123', required: true }
            ]
        },
        rankings: {
            code: 'rk',
            description: 'Get team rankings',
            parameters: [
                { name: 'season', type: 'number', label: 'Season', placeholder: 'e.g., 2024', required: false },
                { name: 'leagueid', type: 'number', label: 'League ID', placeholder: 'e.g., 123', required: false }
            ]
        },
        teams: {
            code: 't',
            description: 'Get team information',
            parameters: [
                { name: 'teamid', type: 'number', label: 'Team ID', placeholder: 'e.g., 45047', required: false }
            ]
        }
    };

    const defaultValues = {
        teamid: 45047,
        memberid: 202665,
        season: new Date().getFullYear(),
        round: 1,
        json: 1
    };

    function updateEndpoint() {
        const endpoint = document.getElementById('endpoint').value;
        const container = document.getElementById('parametersContainer');
        const descDiv = document.getElementById('endpointDescription');
        
        container.innerHTML = '';
        
        if (!endpoint) {
            descDiv.style.display = 'none';
            return;
        }

        const config = endpoints[endpoint];
        descDiv.style.display = 'block';
        document.getElementById('descTitle').textContent = config.description;
        document.getElementById('descText').textContent = `Request code: ${config.code}`;

        // Add parameters
        config.parameters.forEach(param => {
            const div = document.createElement('div');
            div.className = 'form-group';
            
            const label = document.createElement('label');
            label.htmlFor = param.name;
            label.innerHTML = `${param.label} ${param.required ? '<span class="parameter-required">*</span>' : ''}`;
            
            const input = document.createElement('input');
            input.type = param.type;
            input.id = param.name;
            input.name = param.name;
            input.placeholder = param.placeholder;
            input.value = defaultValues[param.name] || '';
            
            div.appendChild(label);
            div.appendChild(input);
            container.appendChild(div);
        });
    }

    async function makeRequest() {
        const endpoint = document.getElementById('endpoint').value;
        const responseBox = document.getElementById('responseBox');

        if (!endpoint) {
            responseBox.className = 'response-box error';
            responseBox.textContent = 'Please select an endpoint.';
            return;
        }

        responseBox.className = 'response-box loading';
        responseBox.textContent = '⏳ Loading...';

        try {
            const params = new URLSearchParams();
            
            // Get all form inputs
            const formInputs = document.querySelectorAll('#parametersContainer input');
            formInputs.forEach(input => {
                if (input.value) {
                    params.append(input.name, input.value);
                }
            });

            const response = await fetch(`/api/test?endpoint=${endpoint}&${params.toString()}`);
            const data = await response.json();

            if (data.success) {
                responseBox.className = 'response-box';
                responseBox.textContent = data.response;
            } else {
                responseBox.className = 'response-box error';
                responseBox.textContent = `Error: ${data.error}`;
            }
        } catch (error) {
            responseBox.className = 'response-box error';
            responseBox.textContent = `Error: ${error.message}`;
        }
    }

    function clearForm() {
        document.getElementById('requestForm').reset();
        document.getElementById('endpoint').value = '';
        document.getElementById('parametersContainer').innerHTML = '';
        document.getElementById('endpointDescription').style.display = 'none';
        document.getElementById('responseBox').className = 'response-box';
        document.getElementById('responseBox').textContent = 'Select an endpoint and send a request to see the response.';
    }

    // Handle Enter key
    document.addEventListener('keypress', function(e) {
        if (e.key === 'Enter' && e.ctrlKey) {
            makeRequest();
        }
    });
</script>
