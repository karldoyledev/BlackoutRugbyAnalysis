            function updateStatsChart() {
                const selectedStat = statSelector.value;
                const stat = statsData[selectedStat];

                if (statsComparisonChart) {
                    statsComparisonChart.destroy();
                }

                statsComparisonChart = new Chart(statsComparisonCanvas, {
                    type: 'bar',
                    data: {
                        labels: stat.names,
                        datasets: [
                            {
                                label: stat.label,
                                data: stat.data,
                                backgroundColor: stat.color,
                                borderRadius: 6
                            }
                        ]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            x: {
                                beginAtZero: true,
                                ticks: {
                                    color: '#415159'
                                },
                                grid: {
                                    color: 'rgba(17, 33, 43, 0.08)'
                                }
                            },
                            y: {
                                ticks: {
                                    color: '#415159'
                                },
                                grid: {
                                    display: false
                                }
                            }
                        }
                    }
                });
            }

            if (statsComparisonCanvas && statSelector) {
                updateStatsChart();
                statSelector.addEventListener('change', updateStatsChart);
            }

            // Handle season changes
            const seasonSelector = document.getElementById('seasonSelector');
            if (seasonSelector) {
                seasonSelector.addEventListener('change', function() {
                    // Find the form and set the season value, then submit
                    const form = document.querySelector('.dashboard-form');
                    if (form) {
                        form.submit();
                    }
                });
            }

            // Auto-load dashboard on page load
            document.addEventListener('DOMContentLoaded', function() {
                const form = document.querySelector('.dashboard-form');
                const loadButton = form?.querySelector('button[asp-page-handler="Load"]');
                if (form && loadButton) {
                    loadButton.click();
                }
            });
        </script>
    }

    @if (comparison is not null)
    {
        var chartChanges = comparison.PlayerChanges.Take(8).ToList();
        var changeLabels = JsonSerializer.Serialize(chartChanges.Select(change => change.Name));
        var csrDeltaData = JsonSerializer.Serialize(chartChanges.Select(change => change.DeltaCsr));
        var pointsDeltaData = JsonSerializer.Serialize(chartChanges.Select(change => change.DeltaTotalPoints));
        var energyDeltaData = JsonSerializer.Serialize(chartChanges.Select(change => change.DeltaEnergy));

        <script>
            const changesCanvas = document.getElementById('changesChart');
            if (changesCanvas) {
                new Chart(changesCanvas, {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(changeLabels),
                        datasets: [
                            {
                                label: 'CSR delta',
                                data: @Html.Raw(csrDeltaData),
                                borderColor: 'rgba(216, 111, 45, 1)',
                                backgroundColor: 'rgba(216, 111, 45, 0.14)',
                                tension: 0.3,
                                fill: true
                            },
                            {
                                label: 'Points delta',
                                data: @Html.Raw(pointsDeltaData),
                                borderColor: 'rgba(45, 138, 88, 1)',
                                backgroundColor: 'rgba(45, 138, 88, 0.12)',
                                tension: 0.3
                            },
                            {
                                label: 'Energy delta',
                                data: @Html.Raw(energyDeltaData),
                                borderColor: 'rgba(37, 96, 107, 1)',
                                backgroundColor: 'rgba(37, 96, 107, 0.12)',
                                tension: 0.3
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                labels: {
                                    usePointStyle: true
                                }
                            }
                        },
                        scales: {
                            x: {
                                ticks: {
                                    color: '#415159'
                                },
                                grid: {
                                    display: false
                                }
                            },
                            y: {
                                ticks: {
                                    color: '#415159'
                                },
                                grid: {
                                    color: 'rgba(17, 33, 43, 0.08)'
                                }
                            }
                        }
                    }
                });
            }
        </script>
    }
