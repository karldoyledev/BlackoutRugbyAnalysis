@page
@model MemberStatsComparisonModel
@using System.Text.Json
@{
    ViewData["Title"] = "Member Stats Comparison";
    var dashboard = Model.Dashboard;
    var gameStats = Model.GameStatsList;
    var fixtureBreakdowns = Model.FixtureBreakdowns;
    var loadedSeason = fixtureBreakdowns.FirstOrDefault()?.TeamStats.Season;
}

<section class="control-panel">
    <form method="post" class="dashboard-form">
        <div class="field-grid">
            <label>
                <span>API endpoint</span>
                <input asp-for="Input.BaseEndpoint" class="form-control" placeholder="https://example.com/api.php" />
                <small asp-validation-for="Input.BaseEndpoint" class="text-danger"></small>
            </label>
            <label>
                <span>Team ID</span>
                <input asp-for="Input.TeamId" class="form-control" placeholder="2" />
                <small asp-validation-for="Input.TeamId" class="text-danger"></small>
            </label>
            <label>
                <span>Season</span>
                <select asp-for="Input.Season" id="seasonSelector" class="form-control">
                    <option value="50">Season 50</option>
                    <option value="51">Season 51</option>
                    <option value="52">Season 52</option>
                    <option value="53">Season 53</option>
                    <option value="54">Season 54</option>
                    <option value="55">Season 55</option>
                    <option value="56">Season 56</option>
                    <option value="57">Season 57</option>
                    <option value="58">Season 58</option>
                    <option value="59">Season 59</option>
                    <option value="60">Season 60</option>
                    <option value="61">Season 61</option>
                    <option value="62">Season 62</option>
                    <option value="63">Season 63</option>
                    <option value="64">Season 64</option>
                    <option value="65">Season 65</option>
                    <option value="66">Season 66</option>
                    <option value="67">Season 67</option>
                    <option value="68">Season 68</option>
                    <option value="69">Season 69</option>
                    <option value="70">Season 70</option>
                    <option value="71">Season 71</option>
                    <option value="72">Season 72</option>
                    <option value="73">Season 73</option>
                    <option value="74">Season 74</option>
                    <option value="75">Season 75</option>
                    <option value="76">Season 76</option>
                    <option value="77">Season 77</option>
                    <option value="78">Season 78</option>
                    <option value="79">Season 79</option>
                    <option value="80">Season 80</option>
                </select>
                <small asp-validation-for="Input.Season" class="text-danger"></small>
            </label>
        </div>
        <div class="button-row">
            <button type="submit" asp-page-handler="Load" class="btn btn-primary action-button">Load stats comparison</button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="error-banner">@Model.ErrorMessage</div>
    }
</section>

@if (dashboard is not null)
{
    <section class="chart-grid">
        <article class="chart-panel full-width-panel">
            <div class="section-heading">
                <h2>Member stats comparison</h2>
                <p>View all squad members ranked by a specific stat.</p>
                <div style="margin-top: 12px;">
                    <label for="statSelector" style="display: inline-block; margin-right: 12px; font-weight: 500;">Select stat:</label>
                    <select id="statSelector" class="form-control" style="display: inline-block; width: auto; max-width: 250px;">
                        <!-- General Stats -->
                        <optgroup label="General">
                            <option value="totalPoints">Total Points</option>
                            <option value="csr">CSR Rating</option>
                            <option value="energy">Energy</option>
                            <option value="form">Form</option>
                            <option value="salary">Salary</option>
                            <option value="age">Age</option>
                        </optgroup>
                        <!-- Match Performance -->
                        <optgroup label="Match Performance">
                            <option value="tackles">Tackles</option>
                            <option value="metresGained">Metres Gained</option>
                            <option value="tries">Tries</option>
                            <option value="conversions">Conversions</option>
                            <option value="dropGoals">Drop Goals</option>
                            <option value="penalties">Penalties</option>
                            <option value="kickingMetres">Kicking Metres</option>
                        </optgroup>
                        <!-- Offensive -->
                        <optgroup label="Offensive">
                            <option value="linebreaks">Linebreaks</option>
                            <option value="beatenDefenders">Beaten Defenders</option>
                            <option value="tryAssists">Try Assists</option>
                            <option value="forwardPasses">Forward Passes</option>
                            <option value="kicksOutOnTheFull">Kicks Out On Full</option>
                            <option value="kicks">Kicks</option>
                        </optgroup>
                        <!-- Defensive -->
                        <optgroup label="Defensive">
                            <option value="missedTackles">Missed Tackles</option>
                            <option value="intercepts">Intercepts</option>
                            <option value="turnoversWon">Turnovers Won</option>
                            <option value="penaltiesConceded">Penalties Conceded</option>
                        </optgroup>
                        <!-- Set Pieces -->
                        <optgroup label="Set Pieces">
                            <option value="successfulLineoutThrows">Successful Lineout Throws</option>
                            <option value="unsuccessfulLineoutThrows">Unsuccessful Lineout Throws</option>
                            <option value="lineoutsSecured">Lineouts Secured</option>
                            <option value="lineoutsConceded">Lineouts Conceded</option>
                            <option value="lineoutsStolen">Lineouts Stolen</option>
                        </optgroup>
                        <!-- Disciplinary -->
                        <optgroup label="Disciplinary">
                            <option value="yellowCards">Yellow Cards</option>
                            <option value="redCards">Red Cards</option>
                            <option value="fights">Fights</option>
                            <option value="injuries">Injuries</option>
                        </optgroup>
                        <!-- Other Stats -->
                        <optgroup label="Other Stats">
                            <option value="knockOns">Knock Ons</option>
                            <option value="handlingErrors">Handling Errors</option>
                            <option value="missedConversions">Missed Conversions</option>
                            <option value="missedDropGoals">Missed Drop Goals</option>
                            <option value="missedPenalties">Missed Penalties</option>
                            <option value="goodUpAndUnders">Good Up And Unders</option>
                            <option value="badUpAndUnders">Bad Up And Unders</option>
                            <option value="upAndUnders">Up And Unders</option>
                            <option value="goodKicks">Good Kicks</option>
                            <option value="badKicks">Bad Kicks</option>
                            <option value="ballTime">Ball Time</option>
                            <option value="penaltyTime">Penalty Time</option>
                        </optgroup>
                        <!-- Caps -->
                        <optgroup label="Caps">
                            <option value="totalCaps">Total Caps</option>
                            <option value="leagueCaps">League Caps</option>
                            <option value="friendlyCaps">Friendly Caps</option>
                            <option value="cupCaps">Cup Caps</option>
                            <option value="nationalCaps">National Caps</option>
                            <option value="underTwentyCaps">Under-20 Caps</option>
                            <option value="worldCupCaps">World Cup Caps</option>
                            <option value="underTwentyWorldCupCaps">U20 World Cup Caps</option>
                            <option value="otherCaps">Other Caps</option>
                        </optgroup>
                    </select>
                </div>
            </div>
            <div class="chart-frame tall-chart">
                <canvas id="statsComparisonChart"></canvas>
            </div>
        </article>

        <article class="chart-panel full-width-panel">
            <div class="section-heading">
                <h2>Member stats breakdown</h2>
                @if (fixtureBreakdowns.Any())
                {
                    <p>Inspect a selected week/game for the whole squad or a single member in the chosen season.</p>
                    <div class="field-grid" style="margin-top: 12px; align-items: end;">
                        <label>
                            <span>Loaded season</span>
                            <input class="form-control" value="@(loadedSeason > 0 ? $"Season {loadedSeason}" : $"Requested season {Model.Input.Season}")" readonly />
                        </label>
                        <label>
                            <span>Select week/game</span>
                            <select id="fixtureBreakdownGameSelector" class="form-control">
                                @foreach (var fixture in fixtureBreakdowns)
                                {
                                    <option value="@fixture.FixtureId">@fixture.Label</option>
                                }
                            </select>
                        </label>
                        <label>
                            <span>Select member</span>
                            <select id="memberBreakdownSelector" class="form-control">
                                <option value="team">Entire team</option>
                                @foreach (var player in dashboard.Players.OrderBy(p => p.Name))
                                {
                                    <option value="@player.Id">@player.Name</option>
                                }
                            </select>
                        </label>
                    </div>
                }
                else
                {
                    <p>No per-game fixture stats were returned for the selected season.</p>
                }
            </div>
            <div class="chart-frame tall-chart">
                <canvas id="memberBreakdownChart"></canvas>
            </div>
        </article>
    </section>
}

@if (gameStats.Any())
{
    var chartLabels = JsonSerializer.Serialize(gameStats.Select(g => $"{g.Date:MMM d} - {g.Opponent}"));
    var tacklesData = JsonSerializer.Serialize(gameStats.Select(g => g.Tackles));
    var metresData = JsonSerializer.Serialize(gameStats.Select(g => g.MetresGained));
    var triesData = JsonSerializer.Serialize(gameStats.Select(g => g.Tries));
    var pointsData = JsonSerializer.Serialize(gameStats.Select(g => g.TotalPoints));

    <section class="chart-grid">
        <article class="chart-panel full-width-panel">
            <div class="section-heading">
                <h2>Team stats per game</h2>
                <p>Team performance across recent matches (most recent first).</p>
            </div>
            <div class="chart-frame tall-chart">
                <canvas id="teamStatsChart"></canvas>
            </div>
        </article>
    </section>

    <section class="table-panel">
        <div class="section-heading">
            <h2>Recent match details</h2>
            <p>Sorted by most recent game first.</p>
        </div>
        <div class="table-responsive">
            <table class="table dashboard-table compact-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Opponent</th>
                        <th>Result</th>
                        <th>Tackles</th>
                        <th>Metres</th>
                        <th>Tries</th>
                        <th>Conversions</th>
                        <th>Drop Goals</th>
                        <th>Penalties</th>
                        <th>Yellow Cards</th>
                        <th>Red Cards</th>
                        <th>Linebreaks</th>
                        <th>Intercepts</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var game in gameStats)
                {
                    <tr>
                        <td>@game.Date.ToString("MMM d, yyyy")</td>
                        <td>@game.Opponent</td>
                        <td>
                            @if (game.Result == "W")
                            {
                                <span class="pill success-pill">@game.Score - @game.OppositionScore (W)</span>
                            }
                            else if (game.Result == "L")
                            {
                                <span class="pill warning-pill">@game.Score - @game.OppositionScore (L)</span>
                            }
                            else
                            {
                                <span class="pill neutral-pill">@game.Score - @game.OppositionScore (D)</span>
                            }
                        </td>
                        <td>@game.Tackles</td>
                        <td>@game.MetresGained</td>
                        <td>@game.Tries</td>
                        <td>@game.Conversions</td>
                        <td>@game.DropGoals</td>
                        <td>@game.Penalties</td>
                        <td>@game.YellowCards</td>
                        <td>@game.RedCards</td>
                        <td>@game.Linebreaks</td>
                        <td>@game.Intercepts</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
}

<partial name="_DebugPanel" />

<script id="apiLogsData" type="application/json">@Html.Raw(Model.ApiLogsJson)</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (dashboard is not null || gameStats.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    }

    @if (dashboard is not null)
    {
        <script>
            // Stats comparison chart with dropdown
            let statsComparisonChart = null;
            const statsComparisonCanvas = document.getElementById('statsComparisonChart');
            const statSelector = document.getElementById('statSelector');
            const memberBreakdownCanvas = document.getElementById('memberBreakdownChart');
            const memberBreakdownSelector = document.getElementById('memberBreakdownSelector');
            const fixtureBreakdownGameSelector = document.getElementById('fixtureBreakdownGameSelector');
            let memberBreakdownChart = null;

            const breakdownFixtures = @Html.Raw(JsonSerializer.Serialize(fixtureBreakdowns.Select(fixture => new {
                fixtureId = fixture.FixtureId,
                label = fixture.Label,
                team = new {
                    id = "team",
                    name = "Entire team",
                    fixture.TeamStats.Tackles,
                    fixture.TeamStats.MetresGained,
                    fixture.TeamStats.Tries,
                    fixture.TeamStats.Conversions,
                    fixture.TeamStats.Linebreaks,
                    fixture.TeamStats.Intercepts,
                    fixture.TeamStats.TotalPoints
