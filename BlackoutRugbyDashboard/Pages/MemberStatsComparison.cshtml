                { key: 'Conversions', label: 'Conversions', color: 'rgba(138, 88, 138, 0.82)' },
                { key: 'Linebreaks', label: 'Linebreaks', color: 'rgba(216, 111, 138, 0.82)' },
                { key: 'Intercepts', label: 'Intercepts', color: 'rgba(45, 111, 216, 0.82)' },
                { key: 'TotalPoints', label: 'Total Points', color: 'rgba(216, 111, 45, 0.82)' }
            ];

            const statsData = {
                // General
                totalPoints: { label: 'Total Points', names: @Html.Raw(JsonSerializer.Serialize(dashboard.Players.OrderByDescending(p => p.TotalPoints).Select(p => p.Name))), data: @Html.Raw(JsonSerializer.Serialize(dashboard.Players.OrderByDescending(p => p.TotalPoints).Select(p => p.TotalPoints))), color: 'rgba(216, 111, 45, 0.82)' },
