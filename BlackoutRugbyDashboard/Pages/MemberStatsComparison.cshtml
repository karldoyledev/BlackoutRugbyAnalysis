            function updateStatsChart() {
                const selectedStat = statSelector.value;
                const stat = statsData[selectedStat];

                if (statsComparisonChart) {
                    statsComparisonChart.destroy();
                }

                statsComparisonChart = new Chart(statsComparisonCanvas, {
                    type: 'bar',
                    data: {
                        labels: stat.names,
                        datasets: [
                            {
                                label: stat.label,
                                data: stat.data,
                                backgroundColor: stat.color,
                                borderRadius: 10
                            }
                        ]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            x: {
                                beginAtZero: true,
                                ticks: {
                                    color: '#415159'
                                },
                                grid: {
                                    color: 'rgba(17, 33, 43, 0.08)'
                                }
                            },
                            y: {
                                ticks: {
                                    color: '#415159'
                                },
                                grid: {
                                    display: false
                                }
                            }
                        }
                    }
                });
            }

            if (statsComparisonCanvas) {
                updateStatsChart();
                statSelector.addEventListener('change', updateStatsChart);
            }

            function updateMemberBreakdownChart() {
                if (!memberBreakdownCanvas || !memberBreakdownSelector || !fixtureBreakdownGameSelector || !breakdownFixtures.length) {
                    return;
                }

                const selectedFixtureId = parseInt(fixtureBreakdownGameSelector.value, 10);
                const selectedSubjectId = memberBreakdownSelector.value;
                const fixture = breakdownFixtures.find(item => item.fixtureId === selectedFixtureId) || breakdownFixtures[0];
                const selected = selectedSubjectId === 'team'
                    ? fixture.team
                    : fixture.players.find(player => String(player.id) === selectedSubjectId) || fixture.players[0] || fixture.team;
                const values = breakdownMetricConfig.map(metric => selected?.[metric.key] ?? 0);

                if (memberBreakdownChart) {
                    memberBreakdownChart.destroy();
                }

                memberBreakdownChart = new Chart(memberBreakdownCanvas, {
                    type: 'bar',
                    data: {
                        labels: breakdownMetricConfig.map(m => m.label),
                        datasets: [{
                            label: `${selected?.name ?? 'Selection'} - ${fixture.label}`,
                            data: values,
                            backgroundColor: breakdownMetricConfig.map(metric => metric.color),
                            borderRadius: 10,
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                labels: {
                                    color: '#415159'
                                }
                            }
                        },
                        scales: {
                            x: {
                                beginAtZero: true,
                                ticks: {
                                    color: '#415159'
                                },
                                grid: {
                                    color: 'rgba(17, 33, 43, 0.12)'
                                }
                            },
                            y: {
                                ticks: {
                                    color: '#415159'
                                },
                                grid: {
                                    display: false
                                }
                            }
                        }
                    }
                });
            }

            if (memberBreakdownCanvas && memberBreakdownSelector && fixtureBreakdownGameSelector) {
                updateMemberBreakdownChart();
                memberBreakdownSelector.addEventListener('change', updateMemberBreakdownChart);
                fixtureBreakdownGameSelector.addEventListener('change', updateMemberBreakdownChart);
            }
        </script>
    }

