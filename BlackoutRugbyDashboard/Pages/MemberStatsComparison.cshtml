            })));

            const breakdownMetricConfig = [
                { key: 'Tackles', label: 'Tackles', color: 'rgba(37, 96, 107, 0.82)' },
                { key: 'MetresGained', label: 'Metres Gained', color: 'rgba(244, 185, 66, 0.82)' },
